{
	"name": "@ilamy/ui",
	"version": "1.8.1",
	"private": true,
	"description": "Shared shadcn UI primitives for the @ilamy/calendar ecosystem.",
	"author": "Sujeet Kc",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kcsujeet/ilamy-calendar.git"
	},
	"type": "module",
	"exports": {
		"./components/*": {
			"types": "./dist/src/components/*.d.ts",
			"import": "./dist/src/components/*.js"
		},
		"./lib/utils": {
			"types": "./dist/src/lib/utils.d.ts",
			"import": "./dist/src/lib/utils.js"
		},
		"./lib/*": {
			"types": "./dist/src/lib/*.d.ts",
			"import": "./dist/src/lib/*.js"
		},
		"./hooks/*": {
			"types": "./dist/src/hooks/*.d.ts",
			"import": "./dist/src/hooks/*.js"
		},
		"./components/input-group": {
			"types": "./dist/src/components/input-group.d.ts",
			"import": "./dist/src/components/input-group.js",
			"require": "./dist/src/components/input-group.js"
		}
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"scripts": {
		"build": "CI=true NODE_ENV=production bunx bunup",
		"type-check": "bunx tsc --noEmit",
		"lint": "bunx biome lint . --diagnostic-level=error",
		"check": "bunx biome check . --diagnostic-level=error",
		"ci": "bun run check && bun run type-check && bun run build"
	},
	"peerDependencies": {
		"react": "^19.2.0",
		"react-dom": "^19.2.0",
		"tailwindcss": "^4.2.2",
		"tailwindcss-animate": "^1.0.7"
	},
	"dependencies": {
		"@base-ui/react": "^1.6.0",
		"@ilamy/utils": "workspace:*",
		"@radix-ui/react-checkbox": "^1.3.3",
		"@radix-ui/react-dialog": "^1.1.15",
		"@radix-ui/react-label": "^2.1.8",
		"@radix-ui/react-popover": "^1.1.15",
		"@radix-ui/react-scroll-area": "^1.2.10",
		"@radix-ui/react-select": "^2.2.6",
		"@radix-ui/react-slot": "^1.2.4",
		"@radix-ui/react-tooltip": "^1.2.8",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"lucide-react": "^0.475.0",
		"radix-ui": "^1.6.2",
		"tailwind-merge": "^3.5.0"
	}
}
